  "item": [
    {
      "name": "Inloggen met geldige gebruiker",
      "item": [
        {
          "name": "Inloggen met geldige gebruiker",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('ST-01: Statuscode is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "})",
                  "",
                  "pm.test('ST-02: Response bevat een accessToken', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('accessToken');",
                  "    pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
                  "})",
                  "",
                  "pm.test('ST-03: Response bevat een tokenType', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('tokenType');",
                  "    pm.expect(json.tokenType).to.eql('Bearer');",
                  "})",
                  "",
                  "pm.test('ST-04: Response bevat een expiresIn waarde', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('expiresIn');",
                  "    pm.expect(json.expiresIn).to.be.a('number').and.above(0);",
                  "})",
                  "",
                  "pm.test('ST-05: Content-Type is application/json', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "})",
                  "",
                  "// Sla het accessToken op als collectievariabele",
                  "const json = pm.response.json();",
                  "if (json && json.accessToken) {",
                  "    pm.collectionVariables.set(\"token\", json.accessToken);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"Test!12345\",\n  \"twoFactorCode\": \"\",\n  \"twoFactorRecoveryCode\": \"\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/identity/login?useCookies=false&useSessionCookies=false",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "identity",
                "login"
              ],
              "query": [
                {
                  "key": "useCookies",
                  "value": "false"
                },
                {
                  "key": "useSessionCookies",
                  "value": "false"
                }
              ]
            }
          },
          "response": []
        }
      ],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Sla het token op na succesvolle login",
              "const json = pm.response.json();",
              "if (json && json.accessToken) {",
              "    pm.collectionVariables.set(\"token\", json.accessToken);",
              "    console.log(\"Token opgeslagen:\", json.accessToken.substring(0, 20) + \"...\");",
              "}"
            ]
          }
        },
