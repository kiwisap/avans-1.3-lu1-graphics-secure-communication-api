      "name": "Ophalen van accountgegevens",
      "item": [
        {
          "name": "Ophalen van accountgegevens",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ST-01: Statuscode is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "})",
                  "",
                  "pm.test('ST-02: Response bevat een e-mailadres', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('email');",
                  "    pm.expect(json.email).to.be.a('string').and.not.empty;",
                  "})",
                  "",
                  "pm.test('ST-03: E-mailadres komt overeen met testgebruiker', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.email).to.eql('test@test.com');",
                  "})",
                  "",
                  "pm.test('ST-04: Content-Type is application/json', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "})"
                ]
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "disabled": true
              },
              {
                "key": "Accept",
                "value": "application/json"
