      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Haal een geldig token op voor het ophalen van accountgegevens",
              "const baseUrl = pm.collectionVariables.get(\"baseUrl\");",
              "",
              "const loginRequest = {",
              "    url: `${baseUrl}/api/identity/login?useCookies=false&useSessionCookies=true`,",
              "    method: \"POST\",",
              "    header: {",
              "        \"Content-Type\": \"application/json\",",
              "        \"Accept\": \"application/json\"",
              "    },",
              "    body: {",
              "        mode: \"raw\",",
              "        raw: JSON.stringify({",
              "            email: \"test@itcure.com\",",
              "            password: \"Test!123\",",
              "            twoFactorCode: \"\",",
              "            twoFactorRecoveryCode: \"\"",
              "        })",
              "    }",
              "};",
              "",
              "pm.sendRequest(loginRequest, function (err, response) {",
              "    if (err) {",
              "        console.error(\"Login mislukt:\", err);",
              "        return;",
              "    }",
              "    const json = response.json();",
              "    if (json && json.accessToken) {",
              "        pm.collectionVariables.set(\"token\", json.accessToken);",
              "        console.log(\"Token succesvol opgehaald.\");",
              "    } else {",
              "        console.error(\"Geen accessToken in response:\", JSON.stringify(json));",
              "    }",
              "});"
            ]
          }
        }
      ]
    },
